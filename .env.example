# 复制本文件为 .env 后填入你自己的值。
# .env 已被 .gitignore 屏蔽，不会上传到 GitHub。
# ⚠️ 旧仓库里曾硬编码过密钥并已公开 → 请到智谱/DeepSeek 控制台「吊销旧 key、重新生成」后再填这里。

# ---- API Keys ----
ZHIPU_API_KEY=your_zhipu_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ---- 知识图谱 / 缓存（项目 03）----
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ---- 模型 ----
# 本地基座（modelscope 下载后的实际路径）
LLM_MODEL_PATH=/root/autodl-tmp/models/Qwen/Qwen2.5-32B-Instruct
# 0 = DeepSeek API（开发期快速验证）；1 = 本地 Qwen2.5-32B（合规/离线）
USE_LOCAL_LLM=0
ZHIPU_EMBEDDING_MODEL=embedding-3

# ---- 向量库 / 文档存储 ----
MILVUS_TEXT_URI=./milvus_agent.db
MILVUS_PDF_URI=./pdf_agent.db
DOCSTORE_PATH=./parent_docstore

# ---- 服务 ----
API_HOST=0.0.0.0
API_PORT=8103

# ---- modelscope 下载目标盘 ----
MODEL_CACHE_DIR=/root/autodl-tmp/models
